                <button class="filter-btn" onclick="filterOrders('confirmed', this)">Confirmed</button>
                <button class="filter-btn" onclick="filterOrders('preparing', this)">Preparing</button>
                <button class="filter-btn" onclick="filterOrders('ready', this)">Ready</button>
                <button class="filter-btn" onclick="filterOrders('delivered', this)">Delivered</button>
                <button class="filter-btn" onclick="filterOrders('cancelled', this)">Cancelled</button>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Phone</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                        <tr>
                            <td colspan="9" class="empty-msg">Loading orders...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ── RESERVATIONS TAB ── -->
        <div class="content" id="tab-reservations">
            <div class="section-header">
                <h3>Reservations</h3>
                <button class="refresh-btn" onclick="loadReservations()"><i class="fas fa-sync"></i> Refresh</button>
            </div>
            <div class="filter-bar">
                <button class="filter-btn active" onclick="filterReservations('', this)">All</button>
                <button class="filter-btn" onclick="filterReservations('pending', this)">Pending</button>
                <button class="filter-btn" onclick="filterReservations('confirmed', this)">Confirmed</button>
                <button class="filter-btn" onclick="filterReservations('cancelled', this)">Cancelled</button>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Guests</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reservationsTableBody">
                        <tr>
                            <td colspan="8" class="empty-msg">Loading reservations...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ── MENU TAB ── -->
        <div class="content" id="tab-menu">
