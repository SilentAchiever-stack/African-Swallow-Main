            <option value="sides">Sides</option>
        </select>
    </div>
    <div class="form-row">
        <input type="number" id="new-price" placeholder="Price (₦) *" min="0" />
        <!-- ✅ File upload instead of URL input -->
        <div style="display:flex;flex-direction:column;gap:6px;">
            <label style="font-size:12px;color:#888;font-weight:700;text-transform:uppercase;">
                Food Image *
            </label>
            <input
                type="file"
                id="new-image-input"
                accept="image/*"
                onchange="handleImageUpload(this)"
                style="padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px;cursor:pointer;"
            />
            <span id="uploadStatus" style="font-size:12px;"></span>
            <img id="imagePreview" src="" alt="Preview"
                style="display:none;width:100%;max-height:120px;object-fit:cover;border-radius:6px;margin-top:4px;">
        </div>
    </div>
    <textarea id="new-description" placeholder="Description *" rows="2"></textarea>
    <label style="font-size:13px;display:flex;align-items:center;gap:6px;margin-bottom:12px;">
        <input type="checkbox" id="new-popular"> Mark as Popular
    </label>
    <button class="submit-add" onclick="addMenuItem()">
        <i class="fas fa-plus"></i> Add Item
    </button>
</div>

